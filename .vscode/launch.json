{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Debug Vitest",
        "type": "node",
        "request": "launch",
        "program": "${workspaceFolder}/scripts/vitest-debug.mjs",
        "args": ["${file}"],
        "cwd": "${workspaceFolder}",
        "console": "integratedTerminal",
        "internalConsoleOptions": "neverOpen",
        "autoAttachChildProcesses": true,
        "smartStep": true,
        "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
      }
    ]
  }