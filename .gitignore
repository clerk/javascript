# See http://help.github.com/ignore-files/ for more about ignoring files.

# compiled output
dist
tmp
out-tsc
out
**/dist/*
**/build/*
packages/*/dist/**
**/.pnpm-store/**

# Vendored upstream sources are NOT build output. Anything under
# packages/*/src/vendor/*/upstream/ is a verbatim copy of an npm tarball and
# must ship with the package; the `dist` and `build` matchers above would
# otherwise silently exclude their `dist/` subdirs from git.
!packages/*/src/vendor/**


# dependencies
node_modules
**/node_modules/**

# IDEs and editors
.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings
**/coverage/**
*.tsbuildinfo

# System Files
.DS_Store
Thumbs.db

# Tooling
.yarn/*
!.yarn/cache
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

.turbo

lerna-debug.log
.next
.dev.vars
.env.local

# Examples apps dependency locks
packages/*/examples/*/package-lock.json
packages/*/examples/*/yarn.lock
/test-results/
/playwright-report/
/playwright/.cache/

# integration testing
.keys.json
.keys.staging.json
.env.json
.temp_integration
playwright-report
test-results
sessions-key.pem
sessions.pem

# pkglab / Verdaccio local registry
.verdaccio

# yalc
.yalc/
yalc.lock

# Release preflight
.release-artifacts/

# Workflow Outputs
/packages/*/*.tgz
/packages/*/tsconfig*.vitest-temp.json
/packages/*/tsup.config.bundled_*

# Scripts
scripts/.env
!scripts/.env.example

# typedoc
.typedoc/docs
.typedoc/docs.json

# Personal Claude prompt
CLAUDE.local.md

# Claude Code local settings (user-specific permissions)
.claude/settings.local.json

# Claude Code per-session runtime lock (not shareable)
.claude/scheduled_tasks.lock

# Git worktrees
.worktrees
