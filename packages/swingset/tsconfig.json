{
  "compilerOptions": {
    "target": "ES2022",
    "module": "preserve",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "lib": ["ES2023", "DOM"],
    "paths": {
      "@/*": ["./src/*"],
      "@clerk/ui/mosaic": ["../ui/src/mosaic"],
      "@clerk/ui/mosaic/*": ["../ui/src/mosaic/*"],
      "@clerk/headless/hooks": ["../headless/src/hooks"],
      "@clerk/headless/*": ["../headless/src/primitives/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "noEmit": true,
    "incremental": true
  },
  "include": ["mdx-components.tsx", "next.config.mjs", "src", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
