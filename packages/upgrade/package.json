{
  "name": "@clerk/upgrade",
  "version": "2.0.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clerk/javascript.git",
    "directory": "packages/upgrade"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "clerk-upgrade": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && NODE_ENV=production babel --keep-file-extension --out-dir=dist src --copy-files",
    "clean": "rm -rf dist/*",
    "dev": "babel --keep-file-extension --out-dir=dist --watch src --copy-files",
    "format": "node ../../scripts/format-package.mjs",
    "format:check": "node ../../scripts/format-package.mjs --check",
    "generate-guide": "node scripts/generate-guide.js",
    "lint": "eslint src/",
    "lint:publint": "publint",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "babel": {
    "presets": [
      "@babel/preset-react"
    ]
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "ejs": "3.1.10",
    "execa": "9.6.1",
    "gray-matter": "^4.0.3",
    "index-to-position": "^0.1.2",
    "jscodeshift": "^17.3.0",
    "marked": "^11.2.0",
    "meow": "^11.0.0",
    "read-pkg": "^9.0.1",
    "semver-regex": "^4.0.5",
    "temp-dir": "^3.0.0",
    "tinyglobby": "^0.2.16"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "@types/jscodeshift": "^0.12.0"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
